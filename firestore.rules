rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsParentDoc(parentUserId) {
      return signedIn() && request.auth.uid == parentUserId;
    }

    match /users/{parentUserId} {
      allow read, write: if ownsParentDoc(parentUserId);

      match /devices/{deviceId} {
        allow read, delete: if ownsParentDoc(parentUserId);
        allow create, update: if ownsParentDoc(parentUserId)
          && request.resource.data.deviceId == deviceId;

        match /events/{eventId} {
          allow read, delete: if ownsParentDoc(parentUserId);
          allow create, update: if ownsParentDoc(parentUserId)
            && request.resource.data.deviceId == deviceId;
        }
      }
    }
  }
}
